{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FlexiTac: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "FlexiTac: Viser Interface",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/Isaacsim_tactile_env/viser_interface.py",
            "args": ["--enable_cameras", "--tactile_backend", "surface_hydro", "--use_bump_pad"],
            "console": "integratedTerminal"
        }
    ]
}
